# Required: Telegram bot token from @BotFather
# Get one at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Required: OpenRouter API key
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Required: MongoDB connection string
MONGO_URI=

# Optional: Override the LLM model (default: minimax/minimax-m2.5:free)
# LLM_MODEL=minimax/minimax-m2.5:free

# Required: Firecrawl API key for web search (get one at https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Optional: Cricket API key (get one at https://cricketdata.org)
# CRICAPI_KEY=

NODE_ENV=
